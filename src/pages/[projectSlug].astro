---
import ProjectTemplate from "../components/ProjectTemplate/ProjectTemplate.astro";

const { projectSlug } = Astro.params;

let project = null;

if (projectSlug) {
  const res = await fetch(
    new URL("/api/projects?slug=" + projectSlug, Astro.request.url)
  );

  project = await res.json();
}
---

{project && <ProjectTemplate project={project} />}
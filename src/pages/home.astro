---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <style>
    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --black: #0a0a0a;
      --black-2: #111111;
      --red: #e02020;
      --red-dark: #a01515;
      --red-glow: rgba(224, 32, 32, 0.18);
      --white: #f5f5f5;
      --white-dim: rgba(245, 245, 245, 0.55);
      --white-faint: rgba(245, 245, 245, 0.08);
      --font-display: "Bebas Neue", sans-serif;
      --font-body: "Barlow", sans-serif;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      background: var(--black);
      color: var(--white);
      font-family: var(--font-body);
      font-weight: 300;
      overflow-x: hidden;
    }

    /* ── NOISE OVERLAY ── */
    body::before {
      content: "";
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
      background-size: 200px 200px;
      pointer-events: none;
      z-index: 9999;
      opacity: 0.35;
    }

    /* ── NAV ── */
    nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 5vw;
      height: 72px;
      background: rgba(10, 10, 10, 0.85);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
      transition: background 0.3s;
    }
    .nav-logo {
      font-family: var(--font-display);
      font-size: 1.55rem;
      letter-spacing: 0.12em;
      color: var(--white);
      text-decoration: none;
    }
    .nav-logo span {
      color: var(--red);
    }
    .nav-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }
    .nav-links a {
      font-family: var(--font-body);
      font-size: 0.78rem;
      font-weight: 400;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      text-decoration: none;
      color: var(--white-dim);
      transition: color 0.25s;
      position: relative;
    }
    .nav-links a::after {
      content: "";
      position: absolute;
      bottom: -4px;
      left: 0;
      width: 0;
      height: 1px;
      background: var(--red);
      transition: width 0.3s ease;
    }
    .nav-links a:hover {
      color: var(--white);
    }
    .nav-links a:hover::after {
      width: 100%;
    }
    .nav-cta {
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      text-decoration: none;
      color: var(--white);
      border: 1px solid var(--red);
      padding: 0.5rem 1.4rem;
      transition:
        background 0.25s,
        color 0.25s;
    }
    .nav-cta:hover {
      background: var(--red);
    }

    /* ── HERO ── */
    .hero {
      position: relative;
      height: 100vh;
      min-height: 640px;
      display: flex;
      align-items: flex-end;
      overflow: hidden;
    }
    .hero-bg {
      position: absolute;
      inset: 0;
      background-image: url("https://images.unsplash.com/photo-1541534741688-6078c6bfb5c5?w=1600&q=80");
      background-size: cover;
      background-position: center 30%;
      transform: scale(1.06);
      animation: heroZoom 14s ease-out forwards;
    }
    @keyframes heroZoom {
      from {
        transform: scale(1.06);
      }
      to {
        transform: scale(1);
      }
    }
    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to top,
        rgba(10, 10, 10, 0.97) 0%,
        rgba(10, 10, 10, 0.55) 45%,
        rgba(10, 10, 10, 0.15) 100%
      );
    }
    .hero-content {
      position: relative;
      z-index: 2;
      padding: 0 5vw 9vh;
      max-width: 820px;
    }
    .hero-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      font-size: 0.72rem;
      font-weight: 400;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--red);
      margin-bottom: 1.2rem;
      opacity: 0;
      animation: fadeUp 0.9s 0.4s ease forwards;
    }
    .hero-eyebrow::before {
      content: "";
      display: block;
      width: 32px;
      height: 1px;
      background: var(--red);
    }
    .hero-title {
      font-family: var(--font-display);
      font-size: clamp(3.8rem, 9vw, 8rem);
      line-height: 0.94;
      letter-spacing: 0.02em;
      color: var(--white);
      margin-bottom: 1.6rem;
      opacity: 0;
      animation: fadeUp 1s 0.65s ease forwards;
    }
    .hero-title em {
      color: var(--red);
      font-style: normal;
    }
    .hero-sub {
      font-size: 1rem;
      font-weight: 300;
      line-height: 1.7;
      color: var(--white-dim);
      max-width: 480px;
      margin-bottom: 2.4rem;
      opacity: 0;
      animation: fadeUp 1s 0.9s ease forwards;
    }
    .hero-actions {
      display: flex;
      gap: 1.2rem;
      align-items: center;
      opacity: 0;
      animation: fadeUp 1s 1.1s ease forwards;
    }
    .btn-primary {
      display: inline-block;
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      text-decoration: none;
      color: var(--white);
      background: var(--red);
      padding: 0.85rem 2.2rem;
      transition:
        background 0.25s,
        transform 0.2s;
    }
    .btn-primary:hover {
      background: var(--red-dark);
      transform: translateY(-2px);
    }
    .btn-ghost {
      display: inline-block;
      font-size: 0.78rem;
      font-weight: 400;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      text-decoration: none;
      color: var(--white-dim);
      transition: color 0.25s;
    }
    .btn-ghost:hover {
      color: var(--white);
    }

    .hero-scroll {
      position: absolute;
      bottom: 2.5rem;
      right: 5vw;
      z-index: 2;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
      opacity: 0;
      animation: fadeIn 1s 1.6s ease forwards;
    }
    .hero-scroll span {
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--white-dim);
      writing-mode: vertical-rl;
    }
    .scroll-line {
      width: 1px;
      height: 56px;
      background: linear-gradient(to bottom, var(--red), transparent);
      animation: scrollPulse 2s 2s infinite;
    }
    @keyframes scrollPulse {
      0%,
      100% {
        opacity: 0.4;
      }
      50% {
        opacity: 1;
      }
    }

    /* ── STATS ── */
    .stats-bar {
      background: var(--black-2);
      border-top: 1px solid rgba(255, 255, 255, 0.06);
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
      display: grid;
      grid-template-columns: repeat(4, 1fr);
    }
    .stat-item {
      padding: 2.6rem 2rem;
      border-right: 1px solid rgba(255, 255, 255, 0.06);
      text-align: center;
      opacity: 0;
      transform: translateY(20px);
      transition:
        opacity 0.7s ease,
        transform 0.7s ease;
    }
    .stat-item:last-child {
      border-right: none;
    }
    .stat-item.visible {
      opacity: 1;
      transform: none;
    }
    .stat-number {
      font-family: var(--font-display);
      font-size: 3rem;
      letter-spacing: 0.04em;
      color: var(--white);
      display: block;
    }
    .stat-number span {
      color: var(--red);
    }
    .stat-label {
      font-size: 0.72rem;
      font-weight: 400;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--white-dim);
      display: block;
      margin-top: 0.3rem;
    }

    /* ── SECTIONS SHARED ── */
    section {
      padding: 7rem 5vw;
    }
    .section-label {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      font-size: 0.72rem;
      font-weight: 400;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--red);
      margin-bottom: 1.2rem;
    }
    .section-label::before {
      content: "";
      display: block;
      width: 28px;
      height: 1px;
      background: var(--red);
    }
    .section-title {
      font-family: var(--font-display);
      font-size: clamp(2.4rem, 5vw, 4rem);
      line-height: 1;
      letter-spacing: 0.03em;
      color: var(--white);
      margin-bottom: 1.4rem;
    }
    .section-body {
      font-size: 1rem;
      line-height: 1.75;
      color: var(--white-dim);
      max-width: 500px;
    }

    /* ── PORTFOLIO GALLERY ── */
    .portfolio {
      background: var(--black);
      padding-bottom: 5rem;
      padding-left: 0;
      padding-right: 0;
      overflow: hidden;
    }
    .portfolio-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      margin-bottom: 3rem;
      padding: 0 5vw;
      flex-wrap: wrap;
      gap: 1.5rem;
    }
    .portfolio > .reveal {
      padding: 0 5vw;
    }

    .filter-tabs {
      display: flex;
      gap: 0.2rem;
    }
    .filter-tab {
      font-size: 0.72rem;
      font-weight: 400;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--white-dim);
      padding: 0.5rem 1.2rem;
      border: 1px solid transparent;
      background: none;
      cursor: pointer;
      transition: all 0.25s;
    }
    .filter-tab.active,
    .filter-tab:hover {
      color: var(--white);
      border-color: rgba(255, 255, 255, 0.12);
    }
    .filter-tab.active {
      border-color: var(--red);
      color: var(--red);
    }

    /* scroll controls row */
    .portfolio-controls {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 0.6rem;
      padding: 0 5vw;
      margin-bottom: 1.8rem;
    }
    .portfolio-progress-wrap {
      flex: 1;
      height: 1px;
      background: rgba(255, 255, 255, 0.08);
      position: relative;
      overflow: hidden;
    }
    .portfolio-progress-bar {
      height: 100%;
      background: var(--red);
      width: 30%;
      transition: width 0.25s ease;
      transform-origin: left;
    }
    .scroll-btn {
      width: 44px;
      height: 44px;
      border: 1px solid rgba(255, 255, 255, 0.12);
      background: none;
      color: var(--white-dim);
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.25s;
      flex-shrink: 0;
    }
    .scroll-btn:hover {
      border-color: var(--red);
      color: var(--red);
    }
    .scroll-btn svg {
      width: 16px;
      height: 16px;
    }

    /* the scrollable track */
    .gallery-track-wrap {
      position: relative;
    }
    .gallery-track-wrap::before,
    .gallery-track-wrap::after {
      content: "";
      position: absolute;
      top: 0;
      bottom: 0;
      width: 8vw;
      pointer-events: none;
      z-index: 2;
    }
    .gallery-track-wrap::before {
      left: 0;
      background: linear-gradient(to right, var(--black), transparent);
    }
    .gallery-track-wrap::after {
      right: 0;
      background: linear-gradient(to left, var(--black), transparent);
    }
    .gallery-track {
      display: flex;
      gap: 3px;
      overflow-x: auto;
      scroll-behavior: smooth;
      padding: 0 5vw 1.5rem;
      scrollbar-width: none;
      -ms-overflow-style: none;
      cursor: grab;
    }
    .gallery-track:active {
      cursor: grabbing;
    }
    .gallery-track::-webkit-scrollbar {
      display: none;
    }

    /* project card */
    .proj-card {
      position: relative;
      flex-shrink: 0;
      overflow: hidden;
      background: var(--black-2);
      cursor: pointer;
    }
    /* size variants */
    .proj-card.tall {
      width: 320px;
      height: 480px;
    }
    .proj-card.wide {
      width: 520px;
      height: 340px;
    }
    .proj-card.square {
      width: 340px;
      height: 340px;
    }

    .proj-card img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition:
        transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94),
        filter 0.5s ease;
      filter: grayscale(25%) brightness(0.88);
    }
    .proj-card:hover img {
      transform: scale(1.07);
      filter: grayscale(0%) brightness(1);
    }
    .proj-card-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        160deg,
        transparent 40%,
        rgba(10, 10, 10, 0.92) 100%
      );
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 1.8rem;
      transition: background 0.4s ease;
    }
    .proj-card:hover .proj-card-overlay {
      background: linear-gradient(
        160deg,
        transparent 20%,
        rgba(10, 10, 10, 0.95) 100%
      );
    }
    .proj-card-cat {
      font-size: 0.65rem;
      font-weight: 400;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--red);
      margin-bottom: 0.4rem;
      transform: translateY(6px);
      opacity: 0.8;
      transition:
        transform 0.35s ease,
        opacity 0.35s ease;
    }
    .proj-card:hover .proj-card-cat {
      transform: none;
      opacity: 1;
    }
    .proj-card-title {
      font-family: var(--font-display);
      font-size: 1.45rem;
      letter-spacing: 0.04em;
      line-height: 1.05;
      color: var(--white);
      margin-bottom: 0.6rem;
      transform: translateY(6px);
      transition: transform 0.35s 0.04s ease;
    }
    .proj-card:hover .proj-card-title {
      transform: none;
    }
    .proj-card-meta {
      display: flex;
      align-items: center;
      gap: 0.8rem;
      opacity: 0;
      transform: translateY(10px);
      transition:
        opacity 0.3s 0.08s ease,
        transform 0.3s 0.08s ease;
    }
    .proj-card:hover .proj-card-meta {
      opacity: 1;
      transform: none;
    }
    .proj-card-meta span {
      font-size: 0.72rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--white-dim);
    }
    .proj-card-meta span + span::before {
      content: "·";
      margin-right: 0.8rem;
      color: rgba(255, 255, 255, 0.2);
    }
    .proj-card-tag {
      position: absolute;
      top: 1.2rem;
      left: 1.2rem;
      font-size: 0.62rem;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--white);
      background: var(--red);
      padding: 0.28rem 0.7rem;
    }
    .proj-card-num {
      position: absolute;
      top: 1.2rem;
      right: 1.4rem;
      font-family: var(--font-display);
      font-size: 3.5rem;
      letter-spacing: 0.04em;
      color: rgba(255, 255, 255, 0.06);
      line-height: 1;
      transition: color 0.3s;
      pointer-events: none;
    }
    .proj-card:hover .proj-card-num {
      color: rgba(224, 32, 32, 0.12);
    }

    /* ── ABOUT ── */
    .about {
      background: var(--black-2);
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 6rem;
      align-items: center;
    }
    .about-image {
      position: relative;
      aspect-ratio: 4/5;
      overflow: hidden;
    }
    .about-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: grayscale(30%);
      transition: filter 0.5s;
    }
    .about-image:hover img {
      filter: grayscale(0%);
    }
    .about-image::after {
      content: "";
      position: absolute;
      bottom: -1.5rem;
      right: -1.5rem;
      width: 40%;
      height: 40%;
      border-right: 3px solid var(--red);
      border-bottom: 3px solid var(--red);
      pointer-events: none;
    }
    .about-image::before {
      content: "";
      position: absolute;
      top: -1.5rem;
      left: -1.5rem;
      width: 40%;
      height: 40%;
      border-left: 3px solid rgba(224, 32, 32, 0.3);
      border-top: 3px solid rgba(224, 32, 32, 0.3);
      pointer-events: none;
      z-index: 1;
    }
    .about-badge {
      position: absolute;
      bottom: 1.5rem;
      right: -2.5rem;
      background: var(--red);
      color: var(--white);
      padding: 1.4rem;
      text-align: center;
      z-index: 2;
      min-width: 110px;
    }
    .about-badge strong {
      display: block;
      font-family: var(--font-display);
      font-size: 2rem;
      letter-spacing: 0.04em;
    }
    .about-badge span {
      display: block;
      font-size: 0.62rem;
      font-weight: 400;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      margin-top: 0.2rem;
    }
    .about-text .section-body {
      margin-bottom: 2rem;
    }
    .about-services {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.8rem;
      margin-top: 2rem;
    }
    .service-chip {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      font-size: 0.78rem;
      font-weight: 400;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--white-dim);
      padding: 0.7rem 0;
      border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    }
    .service-chip::before {
      content: "";
      display: block;
      width: 4px;
      height: 4px;
      background: var(--red);
      flex-shrink: 0;
    }

    /* ── FEATURED WORK ── */
    .featured {
      background: var(--black);
    }
    .featured-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5px;
      margin-top: 3.5rem;
    }
    .featured-item {
      position: relative;
      aspect-ratio: 16/10;
      overflow: hidden;
      cursor: pointer;
    }
    .featured-item.wide {
      grid-column: 1 / 3;
      aspect-ratio: 21/9;
    }
    .featured-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.75s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      filter: brightness(0.75);
    }
    .featured-item:hover img {
      transform: scale(1.06);
      filter: brightness(0.9);
    }
    .featured-caption {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 2.5rem 2rem 1.8rem;
      background: linear-gradient(
        to top,
        rgba(10, 10, 10, 0.9) 0%,
        transparent 100%
      );
      transform: translateY(8px);
      opacity: 0.85;
      transition:
        transform 0.4s ease,
        opacity 0.4s ease;
    }
    .featured-item:hover .featured-caption {
      transform: none;
      opacity: 1;
    }
    .featured-caption-cat {
      font-size: 0.66rem;
      font-weight: 400;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--red);
      margin-bottom: 0.4rem;
    }
    .featured-caption h3 {
      font-family: var(--font-display);
      font-size: 1.5rem;
      letter-spacing: 0.04em;
      color: var(--white);
    }

    /* ── PROCESS ── */
    .process {
      background: var(--black-2);
      text-align: center;
    }
    .process-header {
      max-width: 560px;
      margin: 0 auto 4.5rem;
    }
    .process-header .section-label {
      justify-content: center;
    }
    .process-header .section-label::before {
      display: none;
    }
    .process-steps {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
      position: relative;
    }
    .process-steps::before {
      content: "";
      position: absolute;
      top: 2rem;
      left: 12.5%;
      right: 12.5%;
      height: 1px;
      background: linear-gradient(
        to right,
        transparent,
        var(--red),
        transparent
      );
    }
    .step {
      padding: 0 2rem;
      opacity: 0;
      transform: translateY(24px);
      transition:
        opacity 0.7s ease,
        transform 0.7s ease;
    }
    .step.visible {
      opacity: 1;
      transform: none;
    }
    .step:nth-child(2) {
      transition-delay: 0.15s;
    }
    .step:nth-child(3) {
      transition-delay: 0.3s;
    }
    .step:nth-child(4) {
      transition-delay: 0.45s;
    }
    .step-num {
      width: 4rem;
      height: 4rem;
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 1.8rem;
      font-family: var(--font-display);
      font-size: 1.3rem;
      letter-spacing: 0.06em;
      color: var(--red);
      background: var(--black-2);
      position: relative;
      z-index: 1;
      transition:
        background 0.3s,
        border-color 0.3s;
    }
    .step:hover .step-num {
      background: var(--red);
      color: var(--white);
      border-color: var(--red);
    }
    .step h3 {
      font-family: var(--font-display);
      font-size: 1.15rem;

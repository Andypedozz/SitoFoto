---
import { getOptimizedUrl } from "../../scripts/image";

const { photo } = Astro.props;
---

<style>
    .gallery-item {
        position: relative;
        cursor: pointer;
        overflow: hidden;
        height: 500px;
        transition: all 0.5s ease;
    }

    .gallery-item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: all 0.5s ease;
    }

    .gallery-item:hover {
        transform: translateY(-15px);
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.5);
    }

    .gallery-item:hover img {
        transform: scale(1.08);
    }

    .gallery-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        padding: 25px;
        background: linear-gradient(transparent, rgba(0, 0, 0, 0.95));
        opacity: 0;
        transition: all 0.5s ease;
        transform: translateY(20px);
    }

    .gallery-item:hover .gallery-overlay {
        opacity: 1;
        transform: translateY(0);
    }

    /* ===== MODALE ===== */
    .modal {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.9);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        visibility: hidden;
        transition: all 0.3s ease;
        z-index: 9999;
    }

    .modal.open {
        opacity: 1;
        visibility: visible;
    }

    .modal-close {
        position: absolute;
        top: 20px;
        right: 30px;
        font-size: 2rem;
        color: white;
        cursor: pointer;
    }

    #modal-content img {
        max-width: 90vw;
        max-height: 90vh;
        object-fit: contain;
    }
</style>

<div class="gallery-item" onclick="openModal(this)">
    <img
        src={getOptimizedUrl(photo.secureUrl, 800)}
        srcset={`
            ${getOptimizedUrl(photo.secureUrl, 400)} 400w,
            ${getOptimizedUrl(photo.secureUrl, 800)} 800w,
            ${getOptimizedUrl(photo.secureUrl, 1200)} 1200w
        `}
        sizes="(max-width: 768px) 100vw, 400px"
        width="400"
        height="500"
        loading="lazy"
        alt="photo-card"
    />
</div>

<!-- MODALE -->
<div id="photo-modal" class="modal" onclick="closeModal(event)">
    <span class="modal-close">&times;</span>
    <div id="modal-content"></div>
</div>

<script is:inline>
    const modal = document.getElementById("photo-modal");
    const modalContent = document.getElementById("modal-content");

    window.openModal = (el) => {
        const img = el.querySelector("img");

        // Clona l'immagine già caricata (NO rete)
        const clone = img.cloneNode(true);

        modalContent.innerHTML = "";
        modalContent.appendChild(clone);

        modal.classList.add("open");
    };

    window.closeModal = (e) => {
        if (
            e.target.classList.contains("modal") ||
            e.target.classList.contains("modal-close")
        ) {
            modal.classList.remove("open");
            modalContent.innerHTML = "";
        }
    };

    // chiusura con ESC
    document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") {
            modal.classList.remove("open");
            modalContent.innerHTML = "";
        }
    });
</script>

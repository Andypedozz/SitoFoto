---
import { getOptimizedUrl } from "../../scripts/image";

const { project } = Astro.props;
---
<style>
    .gallery-item {
        position: relative;
        cursor: pointer;
        overflow: hidden;
        height: 500px;
        transition: all 0.5s ease;
    }

    .gallery-item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: all 0.5s ease;
    }

    .gallery-item:hover {
        transform: translateY(-15px);
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.5);
    }

    .gallery-item:hover img {
        transform: scale(1.08);
    }

    .gallery-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        padding: 25px;
        background: linear-gradient(transparent, rgba(0, 0, 0, 0.95));
        opacity: 0;
        transition: all 0.5s ease;
        transform: translateY(20px);
    }

    .gallery-item:hover .gallery-overlay {
        opacity: 1;
        transform: translateY(0);
    }

    .gallery-overlay h3 {
        font-size: 1.5rem;
        margin-bottom: 8px;
    }

    .gallery-overlay p {
        font-size: 1rem;
        color: #cccccc;
    }
</style>
<div class="gallery-item fade-in" onclick=`window.location.href = '/${project.slug}'`>
    <img
        src={getOptimizedUrl(project.copertina, 800)}
        srcset={`
            ${getOptimizedUrl(project.copertina, 400)} 400w,
            ${getOptimizedUrl(project.copertina, 800)} 800w,
            ${getOptimizedUrl(project.copertina, 1200)} 1200w
        `}
        sizes="(max-width: 768px) 100vw, 400px"
        width="400"
        height="500"
        loading="lazy"
        alt="photo-card"
    />
    <div class="gallery-overlay">
        <h3>{project.nome}</h3>
    </div>
</div>
